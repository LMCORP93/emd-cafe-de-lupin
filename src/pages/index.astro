---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BlogHero from '@/components/BlogHero.astro';
import TableOfContents from '@/components/TableOfContents.astro';
import ComparatorCard from '@/components/ComparatorCard.astro';
import SidebarCTA from '@/components/SidebarCTA.astro';
import FAQSection from '@/components/FAQSection.astro';
import ContentImage from '@/components/ContentImage.astro';
import InnerNote from '@/components/InnerNote.astro';
import ComparisonTable from '@/components/ComparisonTable.astro';
import EditorialCriteria from '@/components/EditorialCriteria.astro';
import config from '@/data/site.config';

const topProduct = config.products[0];

const comparatifFaq = [
  {
    question: "Qu'est-ce que le café de lupin ?",
    answer: "Le café de lupin est une boisson chaude préparée à partir de lupin torréfié. Il ne s'agit pas d'un café au sens botanique, mais d'une alternative au café classique, appréciée pour son goût torréfié et son absence naturelle de caféine.",
  },
  {
    question: "Le café de lupin contient-il de la caféine ?",
    answer: "Non, le lupin ne contient naturellement pas de caféine. C'est l'un des principaux intérêts de cette boisson pour les personnes sensibles aux palpitations, au stress, à l'acidité ou aux troubles du sommeil liés au café classique.",
  },
  {
    question: "Quel est le meilleur café de lupin en 2026 ?",
    answer: "Notre choix principal est Lupi Coffee, car la marque est la plus directement positionnée sur le café de lupin bio. Arsène Boisson est une excellente alternative si vous cherchez une recette plus ronde à base de lupin et pois chiche torréfiés.",
  },
  {
    question: "Quelle différence entre Lupi Coffee et Arsène Boisson ?",
    answer: "Lupi Coffee vise le café de lupin bio de façon très directe, avec un prix plus accessible après code promo. Arsène Boisson propose une alternative sans caféine plus gourmande, associant lupin et pois chiche torréfiés, mais à un prix plus élevé.",
  },
  {
    question: "Le café de lupin a-t-il le goût du café ?",
    answer: "Il rappelle davantage le registre torréfié, chaud et réconfortant du café qu'un espresso classique. Le goût est souvent plus doux, végétal et moins amer. Il faut le voir comme une alternative de rituel, pas comme une copie parfaite du café.",
  },
  {
    question: "Où acheter du café de lupin ?",
    answer: "Les deux options les plus simples sont les sites officiels des marques. Lupi Coffee propose le code LMC pour une remise de 15 %, et Arsène Boisson propose le code LMC10 pour une remise de 10 %.",
  },
];

const toAbsoluteUrl = (value: string) => /^https?:\/\//i.test(value) ? value : new URL(value, config.domain).toString();
const numericPrice = (value: string) => String(value ?? '').replace(',', '.').replace(/[^\d.]/g, '');
const productSchema = (p: typeof config.products[number]) => ({
  '@type': 'Product',
  '@id': new URL(`/#product-${p.slug}`, config.domain).toString(),
  name: p.name,
  image: toAbsoluteUrl(p.image),
  description: p.description,
  category: p.productType ?? config.productCategory,
  brand: { '@type': 'Brand', name: p.brand },
  offers: {
    '@type': 'Offer',
    priceCurrency: 'EUR',
    price: numericPrice(p.discountPrice),
    availability: 'https://schema.org/InStock',
    url: p.affiliateLink || config.domain,
    itemCondition: 'https://schema.org/NewCondition',
    shippingDetails: {
      '@type': 'OfferShippingDetails',
      shippingDestination: { '@type': 'DefinedRegion', addressCountry: 'FR' },
      shippingRate: { '@type': 'MonetaryAmount', value: 0, currency: 'EUR' },
      deliveryTime: {
        '@type': 'ShippingDeliveryTime',
        handlingTime: { '@type': 'QuantitativeValue', minValue: 0, maxValue: 2, unitCode: 'DAY' },
        transitTime: { '@type': 'QuantitativeValue', minValue: 2, maxValue: 7, unitCode: 'DAY' },
      },
    },
    hasMerchantReturnPolicy: {
      '@type': 'MerchantReturnPolicy',
      applicableCountry: 'FR',
      returnPolicyCategory: 'https://schema.org/MerchantReturnFiniteReturnWindow',
      merchantReturnDays: 14,
      returnMethod: 'https://schema.org/ReturnByMail',
      returnFees: 'https://schema.org/ReturnFeesCustomerResponsibility',
    },
  },
  aggregateRating: { '@type': 'AggregateRating', ratingValue: p.rating, bestRating: 10, worstRating: 1, reviewCount: p.reviewCount },
});
---

<BaseLayout title={config.seo.title} description={config.seo.description}>
  <script type="application/ld+json" slot="json-ld" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Accueil', item: config.domain },
      { '@type': 'ListItem', position: 2, name: 'Comparatif café de lupin', item: config.domain },
    ],
  })} />

  <script type="application/ld+json" slot="json-ld" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    itemListElement: config.products.map((p, i) => ({ '@type': 'ListItem', position: i + 1, item: productSchema(p) })),
  })} />

  <script type="application/ld+json" slot="json-ld" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: comparatifFaq.map((item) => ({ '@type': 'Question', name: item.question, acceptedAnswer: { '@type': 'Answer', text: item.answer } })),
  })} />

  <BlogHero
    title="Meilleur café de lupin : comparatif 2026"
    description="Lupi Coffee ou Arsène Boisson ? Voici notre comparatif clair des meilleures marques françaises de café de lupin pour remplacer le café sans caféine."
    author={config.author.name}
    authorAvatar={config.author.avatar}
    date="11 Mai 2026"
    readingTime="9 min de lecture"
    breadcrumbs={[{ label: 'Comparatif café de lupin', href: '/' }]}
    bannerImage="/images/content/cafe-de-lupin-hero.webp"
    product={{
      name: topProduct.name,
      image: topProduct.image,
      promoCode: topProduct.promoCode,
      promoPercent: topProduct.promoPercent,
      originalPrice: topProduct.originalPrice,
      discountPrice: topProduct.discountPrice,
      affiliateLink: topProduct.affiliateLink,
    }}
    heroButton={{ text: 'Voir le comparatif', href: `#product-${topProduct.slug}` }}
    showOfferBlock={false}
    showMeta={false}
  />

  <main style="background-color: #ffffff;">
    <div class="container-large padding-global">
      <div class="padding-section-medium">
        <div class="blog-grid">
          <div class="content-column">
            <section id="introduction" class="rich-text intro-section">
              <h2>Notre comparatif des cafés de lupin</h2>
              <p>Le café de lupin répond à une demande très simple : garder le rituel du café, sans caféine, sans nervosité et avec une boisson plus douce pour le quotidien. En France, l’intérêt SEO est réel avec environ <strong>1 600 recherches mensuelles</strong> sur « café de lupin », et l’offre commence seulement à se structurer.</p>
              <p>Ce comparatif met en avant deux marques françaises particulièrement pertinentes : <strong>Lupi Coffee</strong> et <strong>Arsène Boisson</strong>. Ce ne sont pas des produits identiques. Lupi Coffee est le choix le plus direct, centré sur le café de lupin bio. Arsène Boisson propose une alternative plus gourmande, avec lupin et pois chiche torréfiés.</p>
              <p>Notre recommandation est donc claire : <strong>Lupi Coffee en numéro 1</strong> si vous voulez découvrir le café de lupin dans sa forme la plus directe, et <strong>Arsène Boisson en numéro 2</strong> si vous cherchez une boisson chaude sans caféine avec un profil plus rond.</p>
            </section>

            <TableOfContents items={config.tocItems} />

            <section id="ranking" class="comparatif-cards">
              {config.products.map((product) => (
                <div id={`product-${product.slug}`}><ComparatorCard product={product} /></div>
              ))}
            </section>

            <section id="methodologie" class="rich-text seo-guide">
              <h2>Comment nous avons classé les marques</h2>
              <p>Le classement ne repose pas uniquement sur la note globale de la marque. Pour une recherche centrée sur le café de lupin, le premier critère est la pertinence avec l’intention du lecteur. Une personne qui tape « café de lupin » ne cherche pas forcément une boisson fonctionnelle large : elle veut comprendre quelle marque choisir, quel goût attendre, combien cela coûte et si la boisson peut vraiment remplacer le café.</p>
              <p>Nous avons donc donné plus de poids à la spécialisation café de lupin, à la clarté de l’offre, au prix après code promo, à la disponibilité en France, aux avis publics, à la simplicité du lien d’achat et au positionnement sans caféine. C’est ce qui explique le choix de Lupi Coffee en première position, même si Arsène Boisson possède une très bonne note interne.</p>
              <p>Le deuxième critère est l’utilité au moment de choisir. Les deux marques ont un code promo clair, une offre compréhensible et une page d’achat directe. C’est exactement le type de comparatif utile pour le lecteur : court à comprendre, concret pour choisir, et suffisamment précis pour ne pas devenir un article généraliste sur les alternatives au café.</p>
            </section>

            <ContentImage
              src="/images/content/cafe-de-lupin-comparatif.svg"
              alt="Comparatif café de lupin entre Lupi Coffee et Arsène Boisson"
              caption="Pour choisir, le point clé n’est pas seulement le prix : il faut comparer le type de recette, le goût attendu, la présence de caféine, la remise disponible et la facilité d’achat."
            />

            <section id="choisir" class="rich-text seo-guide">
              <h2>Comment choisir son café de lupin ?</h2>
              <h3>Choisissez Lupi Coffee si vous voulez le choix le plus direct</h3>
              <p>Lupi Coffee est le choix logique si votre recherche est vraiment « café de lupin ». La marque est simple à comprendre : une alternative au café à base de lupin bio, sans caféine, pensée pour le rituel du matin. C’est aussi l’option la plus accessible en prix dans notre comparatif, avec un prix affiché à 19,00 € et 17,10 € après le code LMC.</p>
              <p>Ce positionnement direct est important pour un premier achat. Quand une catégorie est encore nouvelle, mieux vaut souvent commencer par la marque la plus lisible plutôt que par l’option la plus complexe. Lupi Coffee coche cette case : promesse claire, produit central facile à identifier, remise propre, et cohérence forte avec la requête SEO.</p>
              <h3>Choisissez Arsène Boisson si vous voulez une alternative plus gourmande</h3>
              <p>Arsène Boisson devient plus intéressante si vous ne cherchez pas seulement du lupin, mais une boisson chaude sans caféine avec une vraie rondeur gustative. La présence de pois chiche torréfié peut donner un profil plus travaillé et moins monolithique. C’est une bonne option pour les personnes qui veulent remplacer le café sans avoir l’impression de boire une simple infusion céréalière.</p>
              <p>Le revers, c’est le prix. À 22,86 € après code LMC10, Arsène Boisson est plus chère que Lupi Coffee. Elle reste pertinente, mais plutôt comme alternative premium ou deuxième test après une première découverte du café de lupin.</p>
            </section>

            <InnerNote emoji="📌" text="Notre lecture : Lupi Coffee est le meilleur point d’entrée sur le café de lupin. Arsène Boisson est la meilleure alternative si vous cherchez un goût plus rond et une recette plus travaillée." />

            <ComparisonTable title="Quel café de lupin choisir ?" headers={[{ label: 'Besoin' }, { label: 'Meilleur choix' }]} rows={[
              { cells: ['Découvrir le café de lupin sans se compliquer', '<a class="table-link" href="https://www.lupicoffee.com/products/cafe-de-lupin-bio-boite-de-decouverte?ref=LMC" target="_blank" rel="nofollow sponsored">✅ Lupi Coffee</a>'], highlight: true },
              { cells: ['Payer le prix le plus accessible après remise', '<a class="table-link" href="https://www.lupicoffee.com/products/cafe-de-lupin-bio-boite-de-decouverte?ref=LMC" target="_blank" rel="nofollow sponsored">✅ Lupi Coffee</a>'], highlight: true },
              { cells: ['Tester une boisson torréfiée plus gourmande', '<a class="table-link" href="https://arseneboissons.fr/LMC10" target="_blank" rel="nofollow sponsored">✅ Arsène Boisson</a>'] },
              { cells: ['Remplacer le café sans caféine', '✅ Les deux marques conviennent'] },
            ]} />

            <section id="prix" class="rich-text seo-guide">
              <h2>Prix et codes promo</h2>
              <p>Côté prix, <strong>Lupi Coffee</strong> part avec un avantage net : 19,00 € avant remise, puis <strong>17,10 € avec le code LMC</strong>. Pour une catégorie encore émergente, ce prix d’entrée est rassurant. Il permet de tester le café de lupin sans engager un panier trop élevé.</p>
              <p><strong>Arsène Boisson</strong> est plus chère : 25,40 € avant remise, puis <strong>22,86 € avec le code LMC10</strong>. Le produit reste intéressant, mais il se place davantage comme une alternative premium. Le choix dépendra donc de votre priorité : tester le lupin au meilleur prix, ou chercher une recette plus gourmande.</p>
              <p>Dans les deux cas, nous recommandons d’acheter via les sites officiels. C’est plus simple pour appliquer les codes promo, vérifier la fraîcheur de l’offre et éviter les fiches marketplace incomplètes.</p>
            </section>

            <EditorialCriteria />

            <section id="verdict" class="rich-text seo-guide">
              <h2>Verdict final</h2>
              <p><strong>Lupi Coffee est notre recommandation numéro 1</strong> pour un comparatif café de lupin. C’est le choix le plus direct, le plus lisible et le plus aligné avec l’intention de recherche. Si vous voulez remplacer le café par une boisson sans caféine à base de lupin, c’est le meilleur point de départ.</p>
              <p><strong>Arsène Boisson mérite clairement sa place en deuxième position</strong>. La marque est crédible, française, bien positionnée et intéressante pour les personnes qui veulent une alternative plus ronde. Elle passe derrière surtout à cause du prix et d’un positionnement un peu moins exact sur le café de lupin pur.</p>
              <p>Notre conseil simple : commencez par Lupi Coffee si vous découvrez la catégorie. Gardez Arsène Boisson comme alternative si vous voulez comparer le goût ou si vous cherchez une boisson chaude sans caféine plus travaillée.</p>
            </section>

            <section id="faq" class="faq-section"><FAQSection faq={comparatifFaq} title="Questions fréquentes" /></section>
          </div>

          <aside class="sidebar-column">
            <div class="sidebar-sticky">
              <SidebarCTA
                logoSrc={topProduct.brandLogo}
                productName={topProduct.name}
                brandName={topProduct.brand}
                promoCode={topProduct.promoCode}
                promoPercent={topProduct.promoPercent}
                originalPrice={topProduct.originalPrice}
                discountPrice={topProduct.discountPrice}
                ctaLink={topProduct.affiliateLink}
                heroImage={topProduct.image}
                rating={topProduct.rating}
                reviewCount={topProduct.reviewCount}
              />
            </div>
          </aside>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .intro-section { margin-bottom: 0.75rem; }
  .seo-guide { margin-top: 3rem; padding-top: 2rem; border-top: 2px solid #f0ebe3; }
  .seo-guide .rich-text h3, .seo-guide h3 { margin-top: 1rem; margin-bottom: .75rem; font-size: 1.25rem; font-weight: 600; color: #242424; }
  .seo-guide p { margin-bottom: 1rem; line-height: 1.625; color: #444; }
  .faq-section { margin-top: 3rem; padding-top: 2rem; border-top: 2px solid #f0ebe3; }
</style>
